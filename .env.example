PORT=3006
NODE_ENV=development

# Número de teléfono del desarrollador: siempre pasa verificación de número,
# sin importar qué correo se use. Solo activo si la variable está definida.
# DEV_BYPASS_PHONE=922495159

# Flujo personalizado por alumno verificado (Rama B en certificados, materiales, etc.)
# false = todos reciben flujo genérico, sin consultar BD por teléfono/correo
ENABLE_VERIFIED_FLOW=true

# Credenciales Odoo (dejar vacíos = usar mock interno)
ODOO_USER=csaavedra055@gmail.com
ODOO_PASS=csaavedra055@gmail.com5

TIMEZONE=America/Lima

# Token de verificación para el webhook de Meta (Middleware Transparente).
# Debe coincidir exactamente con el que configures en Meta Developers → Webhooks.
# Genera un string aleatorio seguro, ej: openssl rand -hex 20
META_VERIFY_TOKEN=cambia_esto_por_un_token_seguro

# URL interna del webhook de Chatwoot donde el bot reenviará cada payload de Meta.
# Encuéntrala en: Chatwoot → Settings → Integrations → WhatsApp → Webhook URL
# Ejemplo: https://chat.we-educacion-ejecutiva.site/webhooks/whatsapp/TU_INBOX_TOKEN
CHATWOOT_META_WEBHOOK_URL=

# Logger espía para Meta Flow responses.
# true    → imprime payload completo solo cuando detecta "Respuesta enviada"
# verbose → imprime TODOS los mensajes entrantes (muy ruidoso, solo para debug puntual)
# false / ausente → desactivado
# DEBUG_FLOW_RESPONSE=true

# Asesora de inscripciones (flujo no-verificado en inscripcion.js)
# Sin estas variables se usan los valores por defecto del código.
PHONE_SALES=51999606366
NAME_SALES=Arleth